# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/finance?schema=public

# API
NODE_ENV=development
PORT=4000
SESSION_SECRET=change-me-to-a-32-byte-random-string-please
SESSION_COOKIE_NAME=ft_session
WEB_ORIGIN=http://localhost:5173
DEFAULT_CURRENCY=USD
SIGNUP_ENABLED=true
RECURRING_CRON_ENABLED=true

# Cookie behaviour. When frontend and API live on different sites (e.g. fintrack.amardito.dev
# and fintrack-api.amardito.dev), browsers won't send cookies on cross-site fetches unless
# the cookie has SameSite=None; Secure.
# Defaults: COOKIE_SAMESITE=lax, COOKIE_SECURE=(true in production, false otherwise).
# COOKIE_SAMESITE=none
# COOKIE_SECURE=true

LOG_LEVEL=info
